<odoo>
    <record id="module_category_sekolah" model="ir.module.category">
        <field name="name">Sekolah</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_guru_staff" model="res.groups">
        <field name="name">Guru Staff</field>
        <field name="category_id" ref="module_category_sekolah"/>
    </record>

    <record id="group_admin_sekolah" model="res.groups">
        <field name="name">Admin Sekolah</field>
        <field name="category_id" ref="module_category_sekolah"/>
        <field name="implied_ids" eval="[(4, ref('group_guru_staff'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="rule_kelas_guru_staff" model="ir.rule">
        <field name="name">Kelas: Guru Staff hanya lihat kelasnya sendiri</field>
        <field name="model_id" ref="model_dev_sekolah_kelas"/>
        <field name="groups" eval="[(4, ref('group_guru_staff'))]"/>
        <field name="domain_force">[
            '|',
            ('wali_kelas_id.user_ids', 'in', [user.id]),
            ('wali_kelas_id', '=', False)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_kelas_admin_sekolah" model="ir.rule">
        <field name="name">Kelas: Admin Sekolah akses semua</field>
        <field name="model_id" ref="model_dev_sekolah_kelas"/>
        <field name="groups" eval="[(4, ref('group_admin_sekolah'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>